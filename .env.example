# Local dev (see README for replica set on localhost)
DATABASE_URL="mongodb://localhost:27017/craner_cms?replicaSet=rs0&directConnection=true"

# Required for JWT cookies
JWT_SECRET="change-me"
# Set false for HTTP-only intranet deployments; set true behind HTTPS
COOKIE_SECURE="false"

# Used only at /admin/register to bootstrap the first superadmin
SUPERADMIN_ACCESS_KEY="change-me-too"
